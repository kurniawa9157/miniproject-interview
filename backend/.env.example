PORT=8080

# Set ke "production" saat deploy (cookie JWT jadi Secure/HTTPS-only)
APP_ENV=development

# PostgreSQL — dipakai backend untuk connect ke DB
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_NAME=miniproject

# PostgreSQL — dipakai service "db" di docker-compose untuk membuat database.
# Nilainya HARUS sama dengan DB_USER/DB_PASSWORD/DB_NAME di atas.
# (Hanya relevan saat deploy via Docker; abaikan untuk dev lokal.)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_DB_PASSWORD_HERE
POSTGRES_DB=miniproject

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# JWT (min 32 karakter)
JWT_SECRET=YOUR_JWT_SECRET_MIN_32_CHARS_HERE

# Admin whitelist (comma-separated email)
ADMIN_EMAILS=your@email.com

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=storage.onelabs.my.id
MINIO_ACCESS_KEY=YOUR_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=YOUR_MINIO_SECRET_KEY
MINIO_BUCKET=jumpapay
MINIO_USE_SSL=true

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:5173

# Midtrans Sandbox (bonus) — daftar di dashboard.midtrans.com
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXXXXXXXXXXXX
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXXXXXXXXXX

# ── Catatan deploy (Docker + reverse proxy) ─────────────────────────────
# Saat produksi, ubah nilai berikut:
#   APP_ENV=production
#   GOOGLE_REDIRECT_URL=https://<domain>/auth/google/callback
#   FRONTEND_URL=https://<domain>
# Dan daftarkan redirect URI di atas ke Google Console.
#
# DB: docker-compose menyertakan service postgres dan otomatis menimpa
# DB_HOST=db, jadi nilai DB_HOST di file ini hanya dipakai saat dev lokal.
# Service db membuat database memakai POSTGRES_USER/PASSWORD/DB — pastikan
# nilainya SAMA dengan DB_USER/DB_PASSWORD/DB_NAME. Migration di
# backend/migrations/ jalan otomatis saat volume postgres pertama kali dibuat.
#
# Frontend dibangun dengan VITE_API_URL="" (relatif), request /api & /auth
# diproxy oleh nginx frontend ke service backend (port 8080, internal).
